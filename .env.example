APP_NAME=legal-mvp-starter
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

QDRANT_URL=https://YOUR-CLUSTER.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=legal_chunks
QDRANT_COLLECTION_HYBRID=legal_chunks_hybrid_v1
QDRANT_EMBEDDING_DIM=1536

DENSE_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
DENSE_EMBEDDING_DEVICE=
DENSE_EMBEDDING_BATCH_SIZE=32
INGEST_CHECKPOINT_DB=data/processed/hybrid_ingest_checkpoint.sqlite3
INGEST_PIPELINE_VERSION=hybrid_v1

ENABLE_WEB_SEARCH=false
FIRECRAWL_API_KEY=
